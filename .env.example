# Public URL used for setup links and email links.
PUBLIC_BASE_URL=https://cfp.example.com

# Public hostname served by Caddy. Must point DNS A/AAAA records to this server.
CADDY_DOMAIN=cfp.example.com

# PostgreSQL connection string.
DATABASE_URL=postgres://paper:paper_password@db:5432/paper_submission

# Set true for production HTTPS behind Caddy.
COOKIE_SECURE=true

# Set true only because the app is behind Caddy and port 3000 is not public.
TRUST_PROXY=true

# Sliding server-side session inactivity timeout in minutes.
# v4 default is 480 (8 hours); set to 30 for a 30-minute idle session.
SESSION_INACTIVITY_MINUTES=480

# 32-byte base64 key for AES-256-GCM SMTP password encryption.
APP_ENCRYPTION_KEY=replace-with-32-byte-base64-key

# Reserved for future object storage support. v1 supports local only.
STORAGE_PROVIDER=local

# Cookie signing secret, at least 32 characters.
COOKIE_SECRET=replace-with-long-random-cookie-secret

# Docker Compose PostgreSQL settings.
POSTGRES_USER=paper
POSTGRES_PASSWORD=paper_password
POSTGRES_DB=paper_submission
