{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "outDir": "dist",
    "rootDir": ".",
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@shared/*": ["src/shared/*"]
    },
    "skipLibCheck": true
  },
  "include": ["src/server/**/*.ts", "src/server/**/*.d.ts", "src/shared/**/*.ts", "migrations/**/*.ts"]
}
